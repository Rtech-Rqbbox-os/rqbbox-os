{
  "name": "rqbbox-os",
  "version": "1.0.0",
  "description": "RQBBOX OS — A high-performance, immersive gaming console OS",
  "main": "src/main.js",
  "author": { "name": "RTech", "email": "dev@rtech.com" },
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --linux",
    "build:all": "electron-builder --linux --x64 --arm64 --armv7l",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.rtech.rqbboxos",
    "productName": "RQBBOX OS",
    "copyright": "Copyright © 2026 RTech",
    "directories": { "output": "dist", "buildResources": "assets" },
    "files": ["src/**/*", "assets/**/*", "node_modules/**/*", "package.json"],
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64", "arm64"] },
        { "target": "deb",      "arch": ["x64", "arm64"] },
        { "target": "rpm",      "arch": ["x64"] },
        { "target": "snap",     "arch": ["x64"] }
      ],
      "icon": "assets/icons",
      "category": "Game",
      "description": "RQBBOX OS — Immersive Gaming Console OS",
      "desktop": {
        "Name": "RQBBOX OS",
        "Comment": "High-performance gaming console operating system",
        "Categories": "Game;Entertainment;"
      }
    },
    "deb": {
      "depends": ["libgtk-3-0", "libnotify4", "libnss3", "libxss1", "libxtst6", "xdg-utils"]
    },
    "snap": {
      "summary": "RQBBOX OS — Immersive Gaming Console OS",
      "grade": "stable",
      "confinement": "strict",
      "plugs": ["network", "network-bind", "desktop", "desktop-legacy", "x11", "audio-playback"]
    },
    "publish": {
      "provider": "github",
      "owner": "Rtech-Rqbbox-os",
      "repo": "rqbbox-os"
    }
  },
  "dependencies": { "electron-updater": "^6.1.7" },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1"
  }
}
