{
  "name": "rqbbox-os",
  "version": "1.0.0",
  "description": "RQBBOX OS — A high-performance, immersive gaming console OS",
  "main": "src/main.js",
  "author": {
    "name": "RTech",
    "email": "dev@rtech.com"
  },
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --mac",
    "build:all": "electron-builder --mac --universal",
    "dist": "npm run build",
    "notarize": "electron-notarize --app-bundle-id com.rtech.rqbboxos --app-path dist/mac/RQBBOX\\ OS.app",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.rtech.rqbboxos",
    "productName": "RQBBOX OS",
    "copyright": "Copyright © 2026 RTech",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["universal"] },
        { "target": "pkg", "arch": ["universal"] },
        { "target": "zip", "arch": ["universal"] }
      ],
      "icon": "assets/icon.icns",
      "bundleVersion": "1",
      "category": "public.app-category.games",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.plist",
      "entitlementsInherit": "entitlements.plist",
      "notarize": {
        "teamId": "${env.APPLE_TEAM_ID}"
      }
    },
    "dmg": {
      "title": "RQBBOX OS ${version}",
      "iconSize": 100,
      "contents": [
        { "x": 380, "y": 170, "type": "link", "path": "/Applications" },
        { "x": 130, "y": 170, "type": "file" }
      ],
      "window": { "width": 540, "height": 380 }
    },
    "publish": {
      "provider": "github",
      "owner": "Rtech-Rqbbox-os",
      "repo": "rqbbox-os"
    }
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1"
  }
}
