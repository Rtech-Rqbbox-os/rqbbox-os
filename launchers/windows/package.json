{
  "name": "rqbbox-os",
  "version": "1.0.0",
  "description": "RQBBOX OS — Windows Launcher",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.rtech.rqbboxos",
    "productName": "RQBBOX OS",
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "installerIcon": "icon.ico",
      "installedIconName": "rqbboxos",
      "shortcutName": "RQBBOX OS"
    }
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  }
}
