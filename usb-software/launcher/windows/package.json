{
  "name": "rqbbox-usb-launcher-windows",
  "version": "1.0.0",
  "description": "RQBBOX OS USB Launcher for Windows — plug in and play",
  "main": "RQBBOXLauncher.js",
  "author": "RTech <gotech@rtechemails.com>",
  "license": "MIT",
  "homepage": "https://inquisitive-rqbbox-core-play.base44.app",
  "repository": "https://github.com/Rtech-Rqbbox-os/rqbbox-os",
  "scripts": {
    "start":          "electron .",
    "build":          "electron-builder --win --x64",
    "build:portable": "electron-builder --win portable",
    "build:all":      "electron-builder --win --x64 --ia32"
  },
  "dependencies": {
    "electron": "^29.0.0"
  },
  "devDependencies": {
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.rtech.rqbbox-usb",
    "productName": "RQBBOX OS",
    "copyright": "Copyright © 2025 RTech",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": ["portable", "nsis"],
      "icon": "../../assets/rqbbox-icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "RQBBOX-OS-USB-${version}-Windows-Setup.exe"
    },
    "portable": {
      "artifactName": "RQBBOX-OS-USB-${version}-Windows.exe"
    }
  }
}
