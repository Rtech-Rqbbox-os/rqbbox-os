{
  "name": "rqbbox-usb-launcher-linux",
  "version": "1.0.0",
  "description": "RQBBOX OS USB Launcher for Linux — plug in and play",
  "main": "RQBBOXLauncher.js",
  "author": "RTech <gotech@rtechemails.com>",
  "license": "MIT",
  "homepage": "https://inquisitive-rqbbox-core-play.base44.app",
  "repository": "https://github.com/Rtech-Rqbbox-os/rqbbox-os",
  "scripts": {
    "start":      "electron .",
    "build":      "electron-builder --linux",
    "build:deb":  "electron-builder --linux deb",
    "build:rpm":  "electron-builder --linux rpm",
    "build:snap": "electron-builder --linux snap",
    "build:all":  "electron-builder --linux AppImage deb rpm snap"
  },
  "dependencies": {
    "electron": "^29.0.0"
  },
  "devDependencies": {
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.rtech.rqbbox-usb",
    "productName": "RQBBOX OS",
    "copyright": "Copyright © 2025 RTech",
    "directories": {
      "output": "dist"
    },
    "linux": {
      "target": ["AppImage", "deb", "rpm", "snap"],
      "icon": "../../assets/rqbbox-icon.png",
      "category": "Game",
      "description": "RQBBOX OS USB — Plug In. Play Anywhere."
    },
    "appImage": {
      "artifactName": "RQBBOX-OS-USB-${version}-Linux.AppImage"
    },
    "deb": {
      "artifactName": "RQBBOX-OS-USB-${version}-Linux.deb"
    },
    "rpm": {
      "artifactName": "RQBBOX-OS-USB-${version}-Linux.rpm"
    }
  }
}
